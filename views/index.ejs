<%- include('partials/header') %>

<section class="relative bg-[#011C40] text-[#A7EBF2]">
  <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(167,235,242,.14),transparent_35%),radial-gradient(circle_at_80%_20%,rgba(38,101,140,.42),transparent_35%)]"></div>

  <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-5 py-20 lg:grid-cols-[1.08fr_.92fr] lg:px-8 lg:py-28">
    <div>
      <p class="section-kicker border-[#54ACBF]/30 bg-[#54ACBF]/10 text-[#A7EBF2]">
        Ingressos online
      </p>

      <h1 class="mt-6 max-w-4xl text-5xl font-black leading-[0.96] tracking-[-0.06em] sm:text-6xl lg:text-7xl">
        <%= subtitulo %>
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-8 text-[#A7EBF2]/75">
        Compre ingressos de forma simples, compare setores, simule valores e gerencie eventos em uma experiência moderna inspirada no TicketMaster.
      </p>

      <div class="mt-9 flex flex-wrap gap-4">
        <a class="btn-primary" href="/eventos">Ver eventos</a>
        <a class="btn-ghost" href="/admin">Gerenciar eventos</a>
      </div>

      <div class="mt-10 grid max-w-2xl grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="mini-card-dark">
          <strong>6</strong>
          <span>páginas</span>
        </div>

        <div class="mini-card-dark">
          <strong>CRUD</strong>
          <span>localStorage</span>
        </div>

        <div class="mini-card-dark">
          <strong>EJS</strong>
          <span>templates</span>
        </div>

        <div class="mini-card-dark">
          <strong>TW</strong>
          <span>Tailwind</span>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -inset-6 rounded-[3rem] bg-gradient-to-br from-[#A7EBF2]/20 to-[#26658C]/35 blur-3xl"></div>

      <div class="animate-float relative rounded-[2rem] border border-[#54ACBF]/20 bg-[#023859]/80 p-5 shadow-2xl shadow-black/30 backdrop-blur-xl">
        <img class="h-[420px] w-full rounded-[1.5rem] bg-[#26658C] object-cover" src="/img/Aurora fest music.png" alt="Imagem do Festival Aurora 2026">

        <div class="mt-5 rounded-[1.5rem] bg-[#A7EBF2] p-5 text-[#011C40] shadow-xl">
          <p class="text-sm font-black uppercase tracking-[0.2em] text-[#26658C]">Evento em destaque</p>

          <h2 class="mt-2 text-2xl font-black">
            Festival Aurora 2026
          </h2>

          <p class="mt-2 text-sm leading-6 text-[#023859]">
            Música, tecnologia, experiência premium e compra de ingressos simulada em poucos cliques.
          </p>

          <div class="mt-4 flex items-center justify-between rounded-2xl bg-[#54ACBF]/30 p-4">
            <span class="font-bold">A partir de</span>
            <strong class="text-2xl text-[#011C40]">R$ 180</strong>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-shell">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="section-kicker bg-[#54ACBF]/20 text-[#26658C]">Eventos</p>
        <h2 class="section-title">Experiências em destaque</h2>
      </div>

      <a class="link-arrow" href="/eventos">Ver todos os eventos</a>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      <% eventosDestaque.forEach((evento) => { %>
        <article class="event-card">
          <div class="relative overflow-hidden rounded-[1.5rem] bg-[#A7EBF2]">
            <img class="h-48 w-full object-cover transition duration-500 hover:scale-105" src="<%= evento.imagem %>" alt="Imagem do evento <%= evento.nome %>">

            <% if (evento.destaque) { %>
              <span class="absolute left-4 top-4 rounded-full bg-[#011C40] px-3 py-1 text-xs font-black uppercase text-[#A7EBF2] shadow-lg">
                Destaque
              </span>
            <% } else { %>
              <span class="absolute left-4 top-4 rounded-full bg-[#26658C] px-3 py-1 text-xs font-black uppercase text-[#A7EBF2] shadow-lg">
                Novo
              </span>
            <% } %>
          </div>

          <div class="p-5">
            <p class="text-sm font-black uppercase tracking-wide text-[#26658C]">
              <%= evento.categoria %>
            </p>

            <h3 class="mt-2 text-xl font-black text-[#011C40]">
              <%= evento.nome %>
            </h3>

            <p class="mt-3 text-sm text-[#023859]">
              <%= evento.cidade %> • <%= evento.data %>
            </p>

            <div class="mt-5 flex items-center justify-between">
              <strong class="text-lg text-[#011C40]">
                R$ <%= evento.preco %>,00
              </strong>

              <a href="/ingressos" class="small-action">Comprar</a>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="bg-[#011C40] px-5 py-16 text-[#A7EBF2] lg:px-8">
  <div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-3">
    <div class="card-glass">
      <span class="text-4xl">🔎</span>
      <h3 class="mt-5 text-2xl font-black">Encontre eventos</h3>
      <p class="mt-3 text-[#A7EBF2]/70">Veja shows, festivais, stand-up e experiências por categoria.</p>
    </div>

    <div class="card-glass">
      <span class="text-4xl">🧮</span>
      <h3 class="mt-5 text-2xl font-black">Calcule ingressos</h3>
      <p class="mt-3 text-[#A7EBF2]/70">Simule quantidade, setor, taxa e valor total da compra.</p>
    </div>

    <div class="card-glass">
      <span class="text-4xl">💾</span>
      <h3 class="mt-5 text-2xl font-black">Gerencie dados</h3>
      <p class="mt-3 text-[#A7EBF2]/70">Cadastre, edite, remova e filtre eventos usando localStorage.</p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>