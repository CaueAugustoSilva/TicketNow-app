<%- include('partials/header') %>

<section class="page-hero">
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <p
      class="section-kicker border-[#00AEEF]/30 bg-[#00AEEF]/10 text-[#BAE6FD]"
    >
      Painel Administrativo
    </p>

    <h1
      class="mt-5 text-5xl font-black tracking-[-0.05em] text-white md:text-6xl"
    >
      <%= titulo %>
    </h1>

    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">
      Gerencie eventos e ingressos de forma visual. Os dados são salvos no
      localStorage e podem ser demonstrados no DevTools.
    </p>
  </div>
</section>

<section class="section-shell">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <section
      class="rounded-[2.5rem] border border-slate-200 bg-white/80 p-5 shadow-2xl shadow-slate-950/10 backdrop-blur md:p-8 lg:p-10"
    >
      <div
        class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
      >
        <div>
          <p class="section-kicker bg-[#00AEEF]/10 text-[#026CDF]">
            CRUD de Eventos
          </p>

          <h2
            class="mt-4 text-4xl font-black tracking-[-0.05em] text-slate-950"
          >
            Cadastro de eventos
          </h2>

          <p class="mt-3 max-w-3xl leading-7 text-slate-600">
            Cadastre, remova e filtre os eventos disponíveis na plataforma. Para
            editar, clique no botão Editar da tabela.
          </p>
        </div>

        <div
          class="rounded-2xl bg-slate-100 px-4 py-3 text-sm font-black text-slate-700"
        >
          <span id="contadorEventos">0 evento(s)</span>
        </div>
      </div>

      <div
        class="mt-10 rounded-[2rem] border border-slate-200 bg-slate-50 p-5 md:p-7"
      >
        <form id="formEvento" class="grid gap-5">
          <input type="hidden" id="eventoId" />

          <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            <div>
              <label for="nomeEvento" class="form-label">Nome do evento</label>
              <input
                id="nomeEvento"
                class="form-control"
                type="text"
                placeholder="Ex: Festival Aurora 2026"
                required
              />
            </div>

            <div>
              <label for="categoriaEvento" class="form-label">Categoria</label>

              <select id="categoriaEvento" class="form-control" required>
                <option value="Música">Música</option>
                <option value="Comédia">Comédia</option>
                <option value="Show">Show</option>
                <option value="Tecnologia">Tecnologia</option>
                <option value="Teatro">Teatro</option>
                <option value="Esporte">Esporte</option>
              </select>
            </div>

            <div>
              <label for="cidadeEvento" class="form-label">Cidade</label>
              <input
                id="cidadeEvento"
                class="form-control"
                type="text"
                placeholder="Ex: Rio de Janeiro"
                required
              />
            </div>

            <div>
              <label for="dataEvento" class="form-label">Data</label>
              <input
                id="dataEvento"
                class="form-control"
                type="date"
                required
              />
            </div>

            <div>
              <label for="precoEvento" class="form-label">Preço base</label>
              <input
                id="precoEvento"
                class="form-control"
                type="number"
                min="0"
                step="0.01"
                placeholder="180"
                required
              />
            </div>

            <div>
              <label for="statusEvento" class="form-label">Status</label>

              <select id="statusEvento" class="form-control" required>
                <option value="Disponível">Disponível</option>
                <option value="Últimos ingressos">Últimos ingressos</option>
                <option value="Esgotado">Esgotado</option>
              </select>
            </div>
          </div>

          <div class="grid gap-3 md:max-w-xl md:grid-cols-2">
            <button id="botaoSalvarEvento" class="btn-primary" type="submit">
              Cadastrar evento
            </button>

            <button
              id="botaoCancelarEvento"
              class="btn-secondary"
              type="button"
            >
              Limpar formulário
            </button>
          </div>
        </form>

        <div id="alertaEventos" class="alerta-sistema oculto"></div>
      </div>

      <div class="mt-10">
        <div
          class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between"
        >
          <div>
            <h3 class="text-3xl font-black tracking-[-0.04em] text-slate-950">
              Tabela de eventos
            </h3>

            <p class="mt-2 text-slate-600">
              Chave do localStorage:
              <span class="code-pill">ticketnow_eventos</span>
            </p>
          </div>

          <div class="w-full md:max-w-md">
            <label for="buscaEvento" class="form-label">Filtrar eventos</label>
            <input
              id="buscaEvento"
              class="form-control"
              type="search"
              placeholder="Busque por nome, categoria, cidade ou status"
            />
          </div>
        </div>

        <div class="table-wrap mt-7">
          <table class="w-full min-w-[850px] border-collapse text-left">
            <thead class="bg-slate-950 text-white">
              <tr>
                <th class="px-5 py-4">Evento</th>
                <th class="px-5 py-4">Categoria</th>
                <th class="px-5 py-4">Cidade</th>
                <th class="px-5 py-4">Data</th>
                <th class="px-5 py-4">Preço</th>
                <th class="px-5 py-4">Status</th>
                <th class="px-5 py-4">Ações</th>
              </tr>
            </thead>

            <tbody
              id="corpoTabelaEventos"
              class="divide-y divide-slate-100 bg-white"
            ></tbody>
          </table>
        </div>
      </div>
    </section>

    <section
      class="mt-14 rounded-[2.5rem] border border-slate-200 bg-white/80 p-5 shadow-2xl shadow-slate-950/10 backdrop-blur md:p-8 lg:p-10"
    >
      <div
        class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
      >
        <div>
          <p class="section-kicker bg-[#00AEEF]/10 text-[#026CDF]">
            CRUD de Ingressos
          </p>

          <h2
            class="mt-4 text-4xl font-black tracking-[-0.05em] text-slate-950"
          >
            Registro de ingressos
          </h2>

          <p class="mt-3 max-w-3xl leading-7 text-slate-600">
            Registre, edite, remova e filtre compras de ingressos vinculadas aos
            eventos cadastrados.
          </p>
        </div>

        <div
          class="rounded-2xl bg-slate-100 px-4 py-3 text-sm font-black text-slate-700"
        >
          <span id="contadorIngressos">0 ingresso(s)</span>
        </div>
      </div>

      <div
        class="mt-10 rounded-[2rem] border border-slate-200 bg-slate-50 p-5 md:p-7"
      >
        <form id="formIngresso" class="grid gap-5">
          <input type="hidden" id="ingressoId" />

          <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            <div>
              <label for="compradorIngresso" class="form-label"
                >Nome do comprador</label
              >
              <input
                id="compradorIngresso"
                class="form-control"
                type="text"
                placeholder="Ex: Ana Carolina"
                required
              />
            </div>

            <div>
              <label for="emailIngresso" class="form-label"
                >E-mail do comprador</label
              >
              <input
                id="emailIngresso"
                class="form-control"
                type="email"
                placeholder="comprador@email.com"
                required
              />
            </div>

            <div>
              <label for="eventoIngresso" class="form-label">Evento</label>
              <select
                id="eventoIngresso"
                class="form-control"
                required
              ></select>
            </div>

            <div>
              <label for="setorIngresso" class="form-label">Setor</label>

              <select id="setorIngresso" class="form-control" required>
                <option value="Pista" data-taxa="12">
                  Pista - taxa R$ 12,00
                </option>
                <option value="Pista Premium" data-taxa="18">
                  Pista Premium - taxa R$ 18,00
                </option>
                <option value="Camarote" data-taxa="30">
                  Camarote - taxa R$ 30,00
                </option>
              </select>
            </div>

            <div>
              <label for="quantidadeIngresso" class="form-label"
                >Quantidade</label
              >
              <input
                id="quantidadeIngresso"
                class="form-control"
                type="number"
                min="1"
                value="1"
                required
              />
            </div>

            <div>
              <label for="statusIngresso" class="form-label"
                >Status do ingresso</label
              >

              <select id="statusIngresso" class="form-control" required>
                <option value="Reservado">Reservado</option>
                <option value="Pago">Pago</option>
                <option value="Cancelado">Cancelado</option>
              </select>
            </div>
          </div>

          <div class="grid gap-3 md:max-w-xl md:grid-cols-2">
            <button id="botaoSalvarIngresso" class="btn-primary" type="submit">
              Registrar ingresso
            </button>

            <button
              id="botaoCancelarIngresso"
              class="btn-secondary"
              type="button"
            >
              Limpar formulário
            </button>
          </div>
        </form>

        <div id="alertaIngressos" class="alerta-sistema oculto"></div>
      </div>

      <div class="mt-10">
        <div
          class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between"
        >
          <div>
            <h3 class="text-3xl font-black tracking-[-0.04em] text-slate-950">
              Tabela de ingressos
            </h3>

            <p class="mt-2 text-slate-600">
              Chave do localStorage:
              <span class="code-pill">ticketnow_ingressos</span>
            </p>
          </div>

          <div class="w-full md:max-w-md">
            <label for="buscaIngresso" class="form-label"
              >Filtrar ingressos</label
            >
            <input
              id="buscaIngresso"
              class="form-control"
              type="search"
              placeholder="Busque por comprador, e-mail, evento, setor ou status"
            />
          </div>
        </div>

        <div class="table-wrap mt-7">
          <table class="w-full min-w-[1000px] border-collapse text-left">
            <thead class="bg-slate-950 text-white">
              <tr>
                <th class="px-5 py-4">Comprador</th>
                <th class="px-5 py-4">E-mail</th>
                <th class="px-5 py-4">Evento</th>
                <th class="px-5 py-4">Setor</th>
                <th class="px-5 py-4">Qtd.</th>
                <th class="px-5 py-4">Total</th>
                <th class="px-5 py-4">Status</th>
                <th class="px-5 py-4">Ações</th>
              </tr>
            </thead>

            <tbody
              id="corpoTabelaIngressos"
              class="divide-y divide-slate-100 bg-white"
            ></tbody>
          </table>
        </div>
      </div>
    </section>
  </div>
</section>

<script src="/js/admin.js"></script>

<%- include('partials/footer') %>
