<%- include('partials/header') %>

<section class="page-hero">
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <p class="section-kicker bg-[#54ACBF]/10 text-[#A7EBF2]">Sobre</p>

    <h1
      class="mt-5 text-5xl font-black tracking-[-0.05em] text-white md:text-6xl"
    >
      <%= titulo %>
    </h1>

    <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
      Uma aplicação acadêmica com utilidade prática: simular compra e gestão de
      ingressos para eventos.
    </p>
  </div>
</section>

<section class="section-shell">
  <div class="mx-auto grid max-w-7xl gap-8 px-5 lg:grid-cols-[1fr_1fr] lg:px-8">
    <div class="card-light">
      <p class="section-kicker bg-pink-100 text-pink-600">Missão</p>

      <h2 class="mt-4 text-4xl font-black tracking-[-0.05em] text-slate-950">
        Facilitar o acesso a eventos
      </h2>

      <p class="mt-5 leading-8 text-slate-600">
        O TicketNow foi criado para resolver um problema real: organizar
        eventos, consultar opções de ingressos e simular o valor final de compra
        de forma simples e visual.
      </p>

      <div class="mt-8 grid gap-4">
        <div class="feature-check">
          <span>✓</span>
          <p>Interface moderna, responsiva e agradável de usar.</p>
        </div>

        <div class="feature-check">
          <span>✓</span>
          <p>Uso de ExpressJS, EJS, Tailwind e CSS externo.</p>
        </div>

        <div class="feature-check">
          <span>✓</span>
          <p>CRUD completo com dados salvos no localStorage.</p>
        </div>
      </div>
    </div>

    <div class="grid gap-6">
      <div class="card-light">
        <p class="section-kicker bg-violet-100 text-violet-600">Valores</p>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-[1.5rem] bg-slate-100 p-5">
            <h3 class="mt-3 text-xl font-black">Rapidez</h3>
            <p class="mt-2 text-sm text-slate-600">
              Compra simulada em poucos cliques.
            </p>
          </div>

          <div class="rounded-[1.5rem] bg-slate-100 p-5">
            <h3 class="mt-3 text-xl font-black">Design</h3>
            <p class="mt-2 text-sm text-slate-600">
              Layout visual, com cards e boas hierarquias.
            </p>
          </div>

          <div class="rounded-[1.5rem] bg-slate-100 p-5">
            <h3 class="mt-3 text-xl font-black">Dados</h3>
            <p class="mt-2 text-sm text-slate-600">
              Persistência usando JSON no navegador.
            </p>
          </div>

          <div class="rounded-[1.5rem] bg-slate-100 p-5">
            <h3 class="mt-3 text-xl font-black">Responsivo</h3>
            <p class="mt-2 text-sm text-slate-600">
              Funciona bem em celular e computador.
            </p>
          </div>
        </div>
      </div>

      <div class="map-fake">
        <div>
          <p
            class="text-sm font-black uppercase tracking-[0.2em] text-pink-300"
          >
            Mapa ilustrativo
          </p>
          <h3 class="mt-2 text-3xl font-black">Eventos pelo Brasil</h3>
          <p class="mt-2 text-slate-300">
            Rio de Janeiro, São Paulo, Belo Horizonte e Curitiba.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
