<%- include('partials/header') %>

<section class="page-hero">
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <p class="section-kicker border-pink-400/30 bg-pink-400/10 text-pink-200">
      Atendimento
    </p>

    <h1
      class="mt-5 text-5xl font-black tracking-[-0.05em] text-white md:text-6xl"
    >
      <%= titulo %>
    </h1>

    <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
      Envie uma mensagem simulada para suporte, parceria ou dúvidas sobre
      eventos.
    </p>
  </div>
</section>

<section class="section-shell">
  <div
    class="mx-auto grid max-w-7xl gap-8 px-5 lg:grid-cols-[.9fr_1.1fr] lg:px-8"
  >
    <div class="card-light">
      <p class="section-kicker bg-pink-100 text-pink-600">Canais</p>

      <h2 class="mt-4 text-4xl font-black tracking-[-0.05em] text-slate-950">
        Fale com a TicketNow
      </h2>

      <div class="mt-8 grid gap-4">
        <div class="contact-card">
          <span>📧</span>
          <div>
            <h3>E-mail</h3>
            <p>contato@ticketnow.com</p>
          </div>
        </div>

        <div class="contact-card">
          <span>📱</span>
          <div>
            <h3>WhatsApp</h3>
            <p>(21) 90000-0000</p>
          </div>
        </div>

        <div class="contact-card">
          <span>📍</span>
          <div>
            <h3>Localização</h3>
            <p>Rio de Janeiro - RJ</p>
          </div>
        </div>
      </div>
    </div>

    <div class="card-light">
      <p class="section-kicker bg-violet-100 text-violet-600">Formulário</p>

      <h2 class="mt-4 text-3xl font-black tracking-[-0.04em] text-slate-950">
        Enviar mensagem
      </h2>

      <form id="formContato" class="mt-8 grid gap-5">
        <div>
          <label for="nomeContato" class="form-label">Nome</label>
          <input
            id="nomeContato"
            class="form-control"
            type="text"
            placeholder="Digite seu nome"
          />
        </div>

        <div>
          <label for="emailContato" class="form-label">E-mail</label>
          <input
            id="emailContato"
            class="form-control"
            type="email"
            placeholder="seuemail@email.com"
          />
        </div>

        <div>
          <label for="assuntoContato" class="form-label">Assunto</label>

          <select id="assuntoContato" class="form-control">
            <option value="">Selecione</option>
            <option value="Compra de ingresso">Compra de ingresso</option>
            <option value="Cadastro de evento">Cadastro de evento</option>
            <option value="Parceria">Parceria</option>
            <option value="Suporte">Suporte</option>
          </select>
        </div>

        <div>
          <label for="mensagemContato" class="form-label">Mensagem</label>

          <textarea
            id="mensagemContato"
            class="form-control min-h-32 resize-y"
            placeholder="Digite sua mensagem"
          ></textarea>
        </div>

        <button class="btn-primary w-full" type="submit">
          Enviar mensagem
        </button>
      </form>

      <div
        id="respostaContato"
        class="mt-6 rounded-3xl bg-slate-100 p-5 text-slate-700"
      >
        A resposta simulada aparecerá aqui.
      </div>
    </div>
  </div>
</section>

<script src="/js/contato.js"></script>

<%- include('partials/footer') %>
