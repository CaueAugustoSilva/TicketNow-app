<%- include('partials/header') %>

<section class="page-hero">
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <p
      class="section-kicker border-[#00AEEF]/30 bg-[#00AEEF]/10 text-[#BAE6FD]"
    >
      Cadastro de ingressos
    </p>

    <h1
      class="mt-5 text-5xl font-black tracking-[-0.05em] text-white md:text-6xl"
    >
      <%= titulo %>
    </h1>

    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">
      Cadastre uma compra de ingresso. Os registros ficam salvos no localStorage
      e podem ser visualizados e gerenciados somente no painel administrativo.
    </p>
  </div>
</section>

<section class="section-shell">
  <div class="mx-auto max-w-5xl px-5 lg:px-8">
    <section class="card-light">
      <p class="section-kicker bg-[#00AEEF]/10 text-[#026CDF]">Nova compra</p>

      <h2 class="mt-4 text-4xl font-black tracking-[-0.05em] text-slate-950">
        Cadastrar ingresso
      </h2>

      <p class="mt-3 leading-7 text-slate-600">
        Preencha os dados abaixo para registrar o ingresso. O total será
        calculado automaticamente.
      </p>

      <form id="formCompraIngresso" class="mt-8 grid gap-5">
        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <label for="compradorCompra" class="form-label"
              >Nome do comprador</label
            >
            <input
              id="compradorCompra"
              class="form-control"
              type="text"
              placeholder="Ex: Ana Carolina"
              required
            />
          </div>

          <div>
            <label for="emailCompra" class="form-label"
              >E-mail do comprador</label
            >
            <input
              id="emailCompra"
              class="form-control"
              type="email"
              placeholder="comprador@email.com"
              required
            />
          </div>
        </div>

        <div>
          <label for="eventoCompra" class="form-label">Evento</label>
          <select id="eventoCompra" class="form-control" required></select>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <label for="setorCompra" class="form-label">Setor</label>

            <select id="setorCompra" class="form-control" required>
              <option value="Pista" data-taxa="12">
                Pista - taxa R$ 12,00
              </option>
              <option value="Pista Premium" data-taxa="18">
                Pista Premium - taxa R$ 18,00
              </option>
              <option value="Camarote" data-taxa="30">
                Camarote - taxa R$ 30,00
              </option>
            </select>
          </div>

          <div>
            <label for="quantidadeCompra" class="form-label">Quantidade</label>
            <input
              id="quantidadeCompra"
              class="form-control"
              type="number"
              min="1"
              value="1"
              required
            />
          </div>
        </div>

        <div
          id="resumoCompra"
          class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5"
        >
          <p class="font-bold text-slate-600">
            Selecione os dados para calcular.
          </p>
        </div>

        <button class="btn-primary w-full" type="submit">
          Cadastrar ingresso
        </button>
      </form>

      <div id="alertaCompraIngresso" class="alerta-sistema oculto"></div>
    </section>
  </div>
</section>

<script src="/js/ingressos.js"></script>

<%- include('partials/footer') %>
