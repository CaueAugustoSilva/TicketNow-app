<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= titulo %></title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>

  <body class="min-h-screen bg-[#011C40] text-slate-900 antialiased">
    <div class="page-orb page-orb-one"></div>
    <div class="page-orb page-orb-two"></div>

    <header
      class="sticky top-0 z-50 border-b border-[#54ACBF]/20 bg-[#023859] shadow-2xl shadow-black/20 backdrop-blur-xl"
    >
      <nav
        class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8"
      >
        <a href="/" class="flex items-center gap-3 text-[#A7EBF2]">
          <span
            class="grid h-11 w-11 place-items-center rounded-2xl bg-gradient-to-br from-[#A7EBF2] via-[#54ACBF] to-[#26658C] text-xl font-black text-[#011C40] shadow-lg shadow-black/20"
          >
            T
          </span>

          <span class="text-2xl font-black tracking-tight">
            Ticket<span class="text-[#54ACBF]">Now</span>
          </span>
        </a>

        <button
          id="menuBotao"
          type="button"
          class="rounded-2xl border border-[#54ACBF]/20 bg-[#023859] px-4 py-2 text-2xl text-[#A7EBF2] transition hover:bg-[#26658C] lg:hidden"
        >
          ☰
        </button>

        <ul
          id="menu"
          class="menu absolute left-5 right-5 top-20 hidden flex-col gap-2 rounded-3xl border border-[#54ACBF]/20 bg-[#023859] p-4 shadow-2xl backdrop-blur-xl lg:static lg:flex lg:flex-row lg:items-center lg:rounded-none lg:border-0 lg:bg-[#023859] lg:p-0 lg:shadow-none"
        >
          <li>
            <a
              class="nav-link <%= paginaAtual === 'index' ? 'nav-link-active' : '' %>"
              href="/"
              >Início</a
            >
          </li>
          <li>
            <a
              class="nav-link <%= paginaAtual === 'eventos' ? 'nav-link-active' : '' %>"
              href="/eventos"
              >Eventos</a
            >
          </li>
          <li>
            <a
              class="nav-link <%= paginaAtual === 'ingressos' ? 'nav-link-active' : '' %>"
              href="/ingressos"
              >Ingressos</a
            >
          </li>
          <li>
            <a
              class="nav-link <%= paginaAtual === 'admin' ? 'nav-link-active' : '' %>"
              href="/admin"
              >Admin</a
            >
          </li>
          <li>
            <a
              class="nav-link <%= paginaAtual === 'sobre' ? 'nav-link-active' : '' %>"
              href="/sobre"
              >Sobre</a
            >
          </li>
          <li>
            <a
              class="nav-link <%= paginaAtual === 'contato' ? 'nav-link-active' : '' %>"
              href="/contato"
              >Contato</a
            >
          </li>
        </ul>
      </nav>
    </header>

    <main class="overflow-hidden"></main>
  </body>
</html>
