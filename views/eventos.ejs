<%- include('partials/header') %>

<section class="page-hero">
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <p class="section-kicker border-pink-400/30 bg-pink-400/10 text-pink-200">
      Catálogo
    </p>

    <h1 class="mt-5 text-5xl font-black tracking-[-0.05em] text-white md:text-6xl">
      <%= titulo %>
    </h1>

    <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
      Filtre os eventos por categoria e encontre a melhor experiência para você.
    </p>
  </div>
</section>

<section class="section-shell">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="mb-8 flex flex-wrap gap-3">
      <% const categorias = ['Todos', 'Música', 'Comédia', 'Show', 'Tecnologia']; %>

      <% categorias.forEach((categoria) => { %>
        <a
          href="/eventos?categoria=<%= categoria %>"
          class="filter-pill <%= categoriaSelecionada === categoria ? 'filter-active' : '' %>"
        >
          <%= categoria %>
        </a>
      <% }) %>
    </div>

    <% if (eventosFiltrados.length > 0) { %>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <% eventosFiltrados.forEach((evento) => { %>
          <article class="event-card">
            <div class="relative overflow-hidden rounded-[1.5rem] bg-slate-100">
              <img class="h-48 w-full object-cover transition duration-500 hover:scale-105" src="<%= evento.imagem %>" alt="Imagem do evento <%= evento.nome %>">

              <% if (evento.destaque) { %>
                <span class="absolute left-4 top-4 rounded-full bg-pink-600 px-3 py-1 text-xs font-black uppercase text-white shadow-lg">
                  Mais buscado
                </span>
              <% } else { %>
                <span class="absolute left-4 top-4 rounded-full bg-violet-600 px-3 py-1 text-xs font-black uppercase text-white shadow-lg">
                  Disponível
                </span>
              <% } %>
            </div>

            <div class="p-5">
              <p class="text-sm font-black uppercase tracking-wide text-pink-500">
                <%= evento.categoria %>
              </p>

              <h2 class="mt-2 text-xl font-black text-slate-950">
                <%= evento.nome %>
              </h2>

              <p class="mt-3 text-sm text-slate-500">
                <%= evento.cidade %> • <%= evento.data %>
              </p>

              <div class="mt-5 flex items-center justify-between">
                <strong class="text-lg text-slate-950">
                  R$ <%= evento.preco %>,00
                </strong>

                <a href="/ingressos" class="small-action">
                  Comprar
                </a>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="rounded-[2rem] border border-slate-200 bg-white p-10 text-center shadow-xl">
        <h2 class="text-2xl font-black text-slate-950">
          Nenhum evento encontrado.
        </h2>

        <p class="mt-3 text-slate-600">
          Tente escolher outra categoria.
        </p>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>